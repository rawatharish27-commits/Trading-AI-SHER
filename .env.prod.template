# ===========================================
# PRODUCTION ENVIRONMENT FILE TEMPLATE
# Trading AI SHER - v4.5
# ===========================================
# ⚠️ SECURITY WARNING:
# - NEVER commit this file to git
# - Use strong random secrets
# - Rotate secrets regularly
# - Use different secrets for each environment
# ===========================================

# ===========================================
# SERVER CONFIGURATION
# ===========================================
NODE_ENV=production
PORT=8080

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
# Option 1: PostgreSQL (RECOMMENDED FOR PRODUCTION)
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Option 2: SQLite (FOR DEVELOPMENT/TESTING)
DATABASE_URL=file:./data/prod.db

# ===========================================
# AI SERVICE (GEMINI)
# ===========================================
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ===========================================
# BROKER CONFIGURATION (ANGEL ONE)
# ===========================================
# Angel One API Key
ANGEL_ONE_API_KEY=your-angel-one-api-key-here

# Angel One Client ID
ANGEL_ONE_CLIENT_ID=your-angel-one-client-id-here

# Angel One Password
ANGEL_ONE_PASSWORD=your-angel-one-password-here

# Angel One TOTP Secret (for 2FA)
ANGEL_ONE_TOTP_SECRET=your-angel-one-totp-secret-here

# ===========================================
# MARKET MODE
# ===========================================
# Options: PAPER (SAFE), LIVE (REAL TRADING)
# WARNING: LIVE MODE WILL PLACE REAL ORDERS
NEXT_PUBLIC_MARKET_MODE=PAPER

# ===========================================
# AUTHENTICATION (NEXTAUTH)
# ===========================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=generate-strong-secret-min-32-characters-here
NEXTAUTH_URL=https://your-production-domain.com

# ===========================================
# JWT AUTHENTICATION
# ===========================================
# Generate with: openssl rand -base64 32
JWT_SECRET=generate-strong-jwt-secret-min-32-characters-here

# ===========================================
# GOOGLE OAUTH (OPTIONAL)
# ===========================================
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# ===========================================
# REDIS CONFIGURATION (RATE LIMITING)
# ===========================================
# Format: redis://host:port
REDIS_URL=redis://localhost:6379

# ===========================================
# STRIPE BILLING (SAAS MONETIZATION)
# ===========================================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key-here
STRIPE_SECRET_KEY=your-stripe-secret-key-here
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret-here

# ===========================================
# SENTRY ERROR TRACKING (OPTIONAL)
# ===========================================
# Get from: https://sentry.io/settings/projects
SENTRY_DSN=your-sentry-dsn-here

# ===========================================
# MONITORING & LOGGING
# ===========================================
LOG_LEVEL=info
LOG_FORMAT=json

# ===========================================
# RATE LIMITING CONFIGURATION
# ===========================================
# Max AI calls per user per minute
NEXT_PUBLIC_AI_RATE_LIMIT=5

# AI response cache TTL in minutes
NEXT_PUBLIC_AI_CACHE_TTL=5

# ===========================================
# SAA SUBSCRIPTION TIERS
# ===========================================
# FREE: 10 AI calls/day
# PRO: 200 AI calls/day
# INSTITUTIONAL: 1000 AI calls/day

# ===========================================
# PERFORMANCE TUNING
# ===========================================
# Database connection pool size (for PostgreSQL)
DB_POOL_MIN=5
DB_POOL_MAX=20

# Request timeout in milliseconds
REQUEST_TIMEOUT=30000

# WebSocket timeout in milliseconds
WS_TIMEOUT=60000

# ===========================================
# ML CONFIGURATION
# ===========================================
# ML model weights file path
ML_MODEL_WEIGHTS_PATH=./model_weights.json

# ML training schedule (cron expression)
ML_TRAINING_SCHEDULE="0 2 * * 0"  # Weekly at 2 AM Sunday

# ===========================================
# COMPLIANCE & LEGAL
# ===========================================
# SEBI registration number (if applicable)
SEBI_REGISTRATION_NUMBER=

# SEBI disclaimer acknowledgment required
SEBI_DISCLAIMER_REQUIRED=true

# Audit logging level
AUDIT_LOG_LEVEL=info

# ===========================================
# DEPLOYMENT CONFIGURATION
# ===========================================
# Deployment environment
DEPLOYMENT_ENVIRONMENT=production

# Deployment timestamp
DEPLOYMENT_TIMESTAMP=$(date +%s)

# Deployment version
DEPLOYMENT_VERSION=4.5.0

# ===========================================
# SECURITY & HARDENING
# ===========================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS=https://your-production-domain.com,https://www.your-production-domain.com

# Maximum file upload size (MB)
MAX_FILE_UPLOAD_SIZE=5

# Session timeout in seconds
SESSION_TIMEOUT=86400

# ===========================================
# FEATURE FLAGS
# ===========================================
# Enable/disable features
FEATURE_ENABLE_AI_ANALYSIS=true
FEATURE_ENABLE_RULE_BASED_FALLBACK=true
FEATURE_ENABLE_ML_CALIBRATION=true
FEATURE_ENABLE_AUTO_RETRAINING=true
FEATURE_ENABLE_WHITE_LABEL_MODE=false
FEATURE_ENABLE_BROKER_EXECUTION=true
FEATURE_ENABLE_PAPER_TRADING=true
FEATURE_ENABLE_LIVE_TRADING=false

# ===========================================
# END OF PRODUCTION ENVIRONMENT FILE
# ===========================================
