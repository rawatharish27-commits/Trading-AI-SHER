# Production Environment Variables for SHER.AI
# Copy this file to .env.production and fill in actual values

# Market Mode
# PAPER: Demo mode with simulated data
# LIVE: Real trading with actual broker connections
MARKET_MODE=PAPER
NODE_ENV=production
PORT=8080

# AI API (Google Gemini)
# Get your API key from: https://makersuite.google.com/app/apikey
API_KEY=your_gemini_api_key_here

# Angel One Broker Credentials (Required for LIVE mode)
# Get these from your Angel One trading account
ANGEL_ONE_API_KEY=your_angel_one_api_key
ANGEL_ONE_CLIENT_ID=your_client_id
ANGEL_ONE_PASSWORD=your_password
ANGEL_ONE_TOTP_SECRET=your_totp_secret

# Database Connection
# For production, use Cloud SQL PostgreSQL or SQLite on persistent disk
# Format: postgresql://user:password@host:port/database
# Or: file:./production.db
DATABASE_URL=postgresql://user:password@localhost:5432/sher_ai

# Optional: Google Cloud Credentials
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
GOOGLE_CLOUD_PROJECT=your-project-id
CLOUDSQL_CONNECTION=project:region:instance

# Optional: Redis for caching (recommended for production)
REDIS_URL=redis://localhost:6379
EVENT_BUS_URL=redis://localhost:6379

# Security
NEXTAUTH_SECRET=your_nextauth_secret_key_here
NEXTAUTH_URL=https://your-domain.com

# Monitoring & Logging
SENTRY_DSN=
LOG_LEVEL=info

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_BACKTESTING=true
ENABLE_SIGNALS=true
